# Провайдер PolzaAI — переменные окружения используются ТОЛЬКО на сервере
# (Vite middleware для локальной разработки + Netlify Functions для продакшна)
# и не попадают в клиентский бандл.
#
# Для Netlify: задайте эти переменные в UI сайта
#   Site settings → Environment variables
# (или через CLI: netlify env:set POLZAAI_API_KEY ...)

POLZAAI_BASE_URL=https://api.polza.ai/v1
POLZAAI_API_KEY=your_polzaai_api_key_here
POLZAAI_MODEL=deepseek/deepseek-v4-pro
# Провайдер для роутинга Polza AI (по умолчанию DeepSeek — самый дешёвый).
# Можно переопределить, например: POLZAAI_PROVIDER=Io Net
POLZAAI_PROVIDER=DeepSeek

# Google Cloud Speech-to-Text API ключ для голосового ввода
GOOGLE_SPEECH_KEY=your_google_speech_api_key_here
